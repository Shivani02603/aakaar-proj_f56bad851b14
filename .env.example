# Connection string for PostgreSQL database
DATABASE_URL=postgresql://username:password@localhost:5432/rag_db

# Secret key for JWT authentication
JWT_SECRET=your_random_secret_key

# Port for the backend FastAPI application
PORT=8000

# API URL for the frontend to communicate with the backend
VITE_API_URL=http://localhost:8000

# OpenAI API key for embedding and querying
OPENAI_API_KEY=your_openai_api_key

# Google Generative AI SDK key for answering questions
ANTHROPIC_API_KEY=your_anthropic_api_key

# Pinecone API key (if using Pinecone for vector storage)
PINECONE_API_KEY=your_pinecone_api_key

# PostgreSQL URL for pgvector service
POSTGRES_URL=postgresql://username:password@localhost:5432/rag_db